root = true

[*]
indent_style             = space
indent_size              = 2
end_of_line              = lf
charset                  = utf-8
trim_trailing_whitespace = true
insert_final_newline     = true

[*.py]
indent_size = 4

[*.rs]
indent_size = 4

[*.java]
indent_size = 4

[*.go]
indent_style = tab
indent_size  = 4

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.{yaml,yml}]
indent_size = 2
