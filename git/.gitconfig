# [user]
#     name = Your Name
#     email = your@email.com
# ↑ 個人情報のため dotfiles には含めない。各自で設定すること:
#   git config --global user.name "Your Name"
#   git config --global user.email "your@email.com"

[core]
    editor = nvim
    autocrlf = input      # WSL: LFで統一、チェックアウト時はそのまま
    excludesfile = ~/.gitignore_global

[init]
    defaultBranch = main

[pull]
    rebase = false

[alias]
    st = status
    lg = log --oneline --graph --decorate --all
    d  = diff
    ds = diff --staged
    co = checkout
    br = branch
    pl = pull
    rb = rebase
    cp = cherry-pick
    undo = reset HEAD~1 --mixed

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

# ローカル設定（個人情報・秘密情報）を別ファイルに分離
[include]
    path = ~/.gitconfig.local
